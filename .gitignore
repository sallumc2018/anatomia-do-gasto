# Dependências e build
apps/web/node_modules/
apps/web/.next/

# Ambiente Python
venv/
__pycache__/
*.pyc
*.pyo

# Variáveis de ambiente (contém caminhos locais)
apps/web/.env.local

# PDFs brutos legados de saude (grandes; podem ser baixados novamente do portal)
data/raw/sorocaba/saude/entrada/

# HTMLs gerados pelo pipeline (redundantes com os CSVs)
data/**/*.html

# Dados intermediários gerados automaticamente
data/extracted/sorocaba/saude/intermediario/

# Ambientes locais Linux/WSL
.venv/

#rtk.exe é um executável específico do ambiente de desenvolvimento, não deve ser versionado
rtk.exe
